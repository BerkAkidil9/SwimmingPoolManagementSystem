# PostgreSQL (default user: postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/swimcenter
# Or use DB_* (postgres password from installation):
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_postgres_password
# DB_NAME=swimcenter

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth Callback Base URL (used for OAuth redirect URIs)
BACKEND_URL=http://localhost:3001

# Session (required for production - use a strong random string)
SESSION_SECRET=your_secret_key_change_in_production

# Cloudflare R2 (for production file storage)
# Render: use Worker proxy - R2_WORKER_URL + R2_WORKER_SECRET (bypasses TLS issues)
# Local dev: direct R2 - R2_ACCOUNT_ID + R2_ACCESS_KEY_ID + R2_SECRET_ACCESS_KEY
R2_WORKER_URL=https://swimcenter-r2-upload.xxx.workers.dev
R2_WORKER_SECRET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=swimcenter-uploads
R2_PUBLIC_URL=https://pub-xxx.r2.dev
USE_R2=true

# Email - Priority: Gmail API > Resend > SMTP (local)
# Gmail API - works on Render, no domain needed. Run scripts/get-gmail-refresh-token.js for token.
GMAIL_USER=your@gmail.com
GMAIL_REFRESH_TOKEN=
# Resend - alternative (requires domain verification)
RESEND_API_KEY=re_xxx
EMAIL_FROM=Swim Center <your@gmail.com>
# SMTP - local fallback only (blocked on Render)
EMAIL_USER=
EMAIL_PASSWORD=

# URLs
FRONTEND_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Frontend build: REACT_APP_STRIPE_PUBLISHABLE_KEY

# Integration tests - swimcenter_test DB (port 5432). See .env.test.example
