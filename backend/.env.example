# PostgreSQL - use DATABASE_URL (Render provides this) or individual vars for local
DATABASE_URL=postgresql://user:password@localhost:5432/swimcenter
# Or:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=swimcenter

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Facebook OAuth
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# OAuth Callback Base URL (used for OAuth redirect URIs)
BACKEND_URL=http://localhost:3001
CALLBACK_URL=http://localhost:3001/auth/callback

# Session (required for production - use a strong random string)
SESSION_SECRET=your_secret_key_change_in_production

# Cloudflare R2 (for production file storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=swimcenter-uploads
R2_PUBLIC_URL=https://pub-xxx.r2.dev
USE_R2=false

# Email
EMAIL_USER=
EMAIL_PASSWORD=

# URLs
FRONTEND_URL=http://localhost:3000

# Stripe (backend - secret key, frontend - create frontend/.env with REACT_APP_STRIPE_PUBLISHABLE_KEY)
STRIPE_SECRET_KEY=
