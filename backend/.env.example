# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=BitirmeProjesi

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Facebook OAuth
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# OAuth Callback Base URL
CALLBACK_URL=http://localhost:3001/auth/callback

# Session Secret
SESSION_SECRET=your_session_secret_here

# Email
EMAIL_USER=
EMAIL_PASSWORD=

# URLs
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=your_secret_key_here

# Stripe (backend - secret key, frontend - create frontend/.env with REACT_APP_STRIPE_PUBLISHABLE_KEY)
STRIPE_SECRET_KEY=
