# PostgreSQL (MySQL'den geçiş: root -> postgres kullanıcısı)
DATABASE_URL=postgresql://user:password@localhost:5432/swimcenter
# Local PostgreSQL (kurulumda belirlediğin postgres şifresi):
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=kurulumda_belirledigin_sifre
# DB_NAME=swimcenter

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth Callback Base URL (used for OAuth redirect URIs)
BACKEND_URL=http://localhost:3001
CALLBACK_URL=http://localhost:3001/auth/callback

# Session (required for production - use a strong random string)
SESSION_SECRET=your_secret_key_change_in_production

# Cloudflare R2 (for production file storage)
# Render'da TLS sorunu için Worker proxy kullanın - R2_WORKER_URL + R2_WORKER_SECRET
# Lokal geliştirme için doğrudan R2: R2_ACCOUNT_ID + R2_ACCESS_KEY_ID + R2_SECRET_ACCESS_KEY
R2_WORKER_URL=https://swimcenter-r2-upload.xxx.workers.dev
R2_WORKER_SECRET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=swimcenter-uploads
R2_PUBLIC_URL=https://pub-xxx.r2.dev
USE_R2=true

# Email - Öncelik: Gmail API > Resend > SMTP (lokal)
# Gmail API - Render'da çalışır, domain gerekmez. scripts/get-gmail-refresh-token.js ile token al.
GMAIL_USER=senin@gmail.com
GMAIL_REFRESH_TOKEN=
# Resend - alternatif (domain doğrulaman gerekir)
RESEND_API_KEY=re_xxx
EMAIL_FROM=Swim Center <senin@gmail.com>
# SMTP - sadece lokal fallback (Render'da engelli)
EMAIL_USER=
EMAIL_PASSWORD=

# URLs
FRONTEND_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Frontend build: REACT_APP_STRIPE_PUBLISHABLE_KEY

# Integration tests - swimcenter_test DB (port 5432). .env.test.example'a bak
