# Integration tests - swimcenter_test database (local PostgreSQL)
# Copy to backend/.env.test (gitignored)
# Use your postgres user password from PostgreSQL installation.
# For Neon/cloud: TEST_DATABASE_URL=postgresql://...@xxx.neon.tech/swimcenter_test?sslmode=require

TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_USER=postgres
TEST_DB_PASSWORD=
TEST_DB_NAME=swimcenter_test
