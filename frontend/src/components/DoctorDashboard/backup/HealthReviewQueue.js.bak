import React, { useState, useEffect } from 'react';
import { Card, Row, Col, Badge, Button, Form, Spinner, ListGroup, Alert } from 'react-bootstrap';
import { FaNotesMedical, FaHeartbeat, FaWeight, FaRulerVertical, FaUserMd, FaAllergies, FaSearch, FaMedkit, FaFileMedical, FaEye, FaFileDownload, FaFilter, FaClock, FaFileUpload, FaUserCheck } from 'react-icons/fa';
import axios from 'axios';
import './css/HealthReviewQueue.css';

const HealthReviewQueue = () => {
  const [patients, setPatients] = useState([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);
  const [currentPatient, setCurrentPatient] = useState(null);
  const [showApprovalModal, setShowApprovalModal] = useState(false);
  const [showReportModal, setShowReportModal] = useState(false);
  const [showRejectModal, setShowRejectModal] = useState(false);
  const [showHealthReportsModal, setShowHealthReportsModal] = useState(false);
  const [searchTerm, setSearchTerm] = useState('');
  const [approvalReason, setApprovalReason] = useState('');
  const [reportReason, setReportReason] = useState('');
  const [rejectReason, setRejectReason] = useState('');
  const [processing, setProcessing] = useState(false);
  const [healthReports, setHealthReports] = useState([]);
  const [loadingReports, setLoadingReports] = useState(false);
  const [activeFilter, setActiveFilter] = useState('all'); // 'all', 'initial', 'requested', 'uploaded'

  const fetchPatients = async () => {
    try {
      setLoading(true);
      const response = await axios.get('/api/doctor/health-reviews');
      setPatients(response.data);
      setError(null);
      
      // Log information about report counts and status for debugging
      console.log('Patients data:', response.data.map(p => ({
        id: p.id,
        name: `${p.name} ${p.surname}`,
        status: p.health_status,
        reportCount: p.reportCount,
        hasUploadedAfterRequest: p.hasUploadedAfterRequest
      })));
    } catch (err) {
      setError('Error fetching patients: ' + (err.response?.data?.error || err.message));
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    fetchPatients();
  }, []);

  const handleRequestReport = async () => {
    if (!reportReason.trim()) {
      return;
    }

    try {
      setProcessing(true);
      await axios.put(`/api/doctor/health-status/${currentPatient.id}`, {
        status: 'needs_report',
        reason: reportReason
      });
      
      setShowReportModal(false);
      setReportReason('');
      setCurrentPatient(null);
      
      // Update the patient list
      fetchPatients();
    } catch (err) {
      setError('Error requesting health report: ' + (err.response?.data?.error || err.message));
    } finally {
      setProcessing(false);
    }
  };

  const handleApprove = async () => {
    try {
      setProcessing(true);
      await axios.put(`/api/doctor/health-status/${currentPatient.id}`, {
        status: 'approved',
        reason: approvalReason
      });
      
      setShowApprovalModal(false);
      setApprovalReason('');
      setCurrentPatient(null);
      
      // Update the patient list
      fetchPatients();
    } catch (err) {
      setError('Error approving health status: ' + (err.response?.data?.error || err.message));
    } finally {
      setProcessing(false);
    }
  };

  const handleReject = async () => {
    if (!rejectReason.trim()) {
      return;
    }

    try {
      setProcessing(true);
      await axios.put(`/api/doctor/health-status/${currentPatient.id}`, {
        status: 'rejected',
        reason: rejectReason
      });
      
      setShowRejectModal(false);
      setRejectReason('');
      setCurrentPatient(null);
      
      // Update the patient list
      fetchPatients();
    } catch (err) {
      setError('Error rejecting health status: ' + (err.response?.data?.error || err.message));
    } finally {
      setProcessing(false);
    }
  };

  const handleViewDetails = (patient) => {
    setCurrentPatient(patient);
  };

  const handleShowApprovalModal = (patient) => {
    setCurrentPatient(patient);
    setShowApprovalModal(true);
    setApprovalReason('');
  };

  const handleShowReportModal = (patient) => {
    setCurrentPatient(patient);
    setShowReportModal(true);
    setReportReason('');
  };
  
  const handleShowRejectModal = (patient) => {
    setCurrentPatient(patient);
    setShowRejectModal(true);
    setRejectReason('');
  };

  const fetchHealthReports = async (userId) => {
    try {
      setLoadingReports(true);
      const response = await axios.get(`/api/doctor/health-reports/${userId}`);
      setHealthReports(response.data);
      setShowHealthReportsModal(true);
    } catch (err) {
      setError('Error fetching health reports: ' + (err.response?.data?.error || err.message));
    } finally {
      setLoadingReports(false);
    }
  };

  const handleViewHealthReports = (patient) => {
    setCurrentPatient(patient);
    fetchHealthReports(patient.id);
  };

  const formatDate = (dateString) => {
    const date = new Date(dateString);
    return date.toLocaleDateString() + ' ' + date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  };

  const filteredPatients = patients.filter(patient => {
    // First apply text search filter
    const searchTermLower = searchTerm.toLowerCase();
    const matchesSearch = (
      patient.name.toLowerCase().includes(searchTermLower) ||
      patient.surname.toLowerCase().includes(searchTermLower) ||
      patient.email.toLowerCase().includes(searchTermLower) ||
      (patient.phone && patient.phone.includes(searchTerm))
    );
    
    if (!matchesSearch) return false;
    
    // Then apply status filter
    switch (activeFilter) {
      case 'initial':
        // Initial review (pending health status, never been requested a report)
        return patient.health_status === 'pending' && !patient.hasUploadedAfterRequest && patient.reportCount === 0;
      case 'requested': 
        // Report requested (needs_report status)
        return patient.health_status === 'needs_report';
      case 'uploaded':
        // Has uploaded reports (either reportCount > 0 or has uploaded after request)
        return patient.reportCount > 0 || (patient.health_status === 'pending' && patient.hasUploadedAfterRequest);
      case 'all':
      default:
        return true; // No additional filtering
    }
  });

  // Get appropriate badge based on status and additional context
  const getStatusBadge = (patient) => {
    // Report uploaded after request
    if (patient.health_status === 'pending' && patient.hasUploadedAfterRequest) {
      return (
        <Badge bg="primary" className="status-badge status-uploaded">
          <FaFileUpload className="me-1" /> Uploaded After Request
        </Badge>
      );
    }
    
    // Report was requested
    if (patient.health_status === 'needs_report') {
      return (
        <Badge bg="warning" className="status-badge status-requested">
          <FaClock className="me-1" /> Awaiting Report
        </Badge>
      );
    }
    
    // Initial review
    return (
      <Badge bg="secondary" className="status-badge status-initial">
        <FaUserCheck className="me-1" /> Initial Review
      </Badge>
    );
  };
  
  // Get report count badge if applicable
  const getReportBadge = (reportCount) => {
    if (reportCount > 0) {
      return (
        <Badge pill bg="info" className="report-count-badge">
          {reportCount} {reportCount === 1 ? 'Report' : 'Reports'}
        </Badge>
      );
    }
    return null;
  };
  
  // Determine card CSS class based on patient status
  const getCardClass = (patient) => {
    let className = "health-review-card ";
    
    if (patient.reportCount > 0) {
      className += "has-reports ";
    }
    
    if (patient.health_status === 'pending' && patient.hasUploadedAfterRequest) {
      className += "uploaded-after-request";
    }
    
    return className;
  };

  return (
    <div className="health-review-queue">
      <Card className="panel-card">
        <Card.Header>
          <div className="d-flex justify-content-between align-items-center">
            <h3 className="text-dark"><FaNotesMedical className="me-2" /> Health Information Reviews</h3>
            <div className="search-container">
              <div className="position-relative">
                <Form.Control
                  type="text"
                  placeholder="Search patients..."
                  value={searchTerm}
                  onChange={(e) => setSearchTerm(e.target.value)}
                  className="search-input"
                />
                <FaSearch className="search-icon" />
              </div>
            </div>
          </div>
        </Card.Header>
        <Card.Body>
          {/* Filter tabs */}
          <div className="filter-tabs d-flex mb-3">
            <div 
              className={`filter-tab d-flex align-items-center ${activeFilter === 'all' ? 'active' : ''}`}
              onClick={() => setActiveFilter('all')}
            >
              <FaFilter className="me-1" /> All ({patients.length})
            </div>
            <div 
              className={`filter-tab d-flex align-items-center ${activeFilter === 'initial' ? 'active' : ''}`}
              onClick={() => setActiveFilter('initial')}
            >
              <FaUserCheck className="me-1" /> Initial Review ({patients.filter(p => p.health_status === 'pending' && !p.hasUploadedAfterRequest && p.reportCount === 0).length})
            </div>
            <div 
              className={`filter-tab d-flex align-items-center ${activeFilter === 'requested' ? 'active' : ''}`}
              onClick={() => setActiveFilter('requested')}
            >
              <FaClock className="me-1" /> Awaiting Reports ({patients.filter(p => p.health_status === 'needs_report').length})
            </div>
            <div 
              className={`filter-tab d-flex align-items-center ${activeFilter === 'uploaded' ? 'active' : ''}`}
              onClick={() => setActiveFilter('uploaded')}
            >
              <FaFileUpload className="me-1" /> With Reports ({patients.filter(p => p.reportCount > 0 || (p.health_status === 'pending' && p.hasUploadedAfterRequest)).length})
            </div>
          </div>
          
          {loading ? (
            <div className="text-center py-5">
              <Spinner animation="border" role="status" variant="primary">
                <span className="visually-hidden">Loading...</span>
              </Spinner>
              <p className="mt-2 text-dark">Loading patients...</p>
            </div>
          ) : error ? (
            <div className="alert alert-danger">{error}</div>
          ) : filteredPatients.length === 0 ? (
            <div className="no-data-message">
              <FaNotesMedical />
              <h4 className="text-dark">No patients matching the current filters</h4>
              <p className="text-muted">Try changing your search or filter criteria.</p>
            </div>
          ) : (

            <Row xs={1} md={1} className="g-4">
              {filteredPatients.map((patient) => (

const getHealthStatusBadge = (status) => {
  switch(status) {
    case 'pending':
      return <Badge className="health-status-badge status-pending">Pending Review</Badge>;
    case 'approved':
      return <Badge className="health-status-badge status-approved">Approved</Badge>;
    case 'needs_report':
      return <Badge className="health-status-badge status-needs-report">Report Requested</Badge>;
    default:
      return <Badge className="health-status-badge status-pending">Unknown</Badge>;
  }
};

return (
  <div className="health-review-queue">
    <Card className="panel-card">
      <Card.Header>
        <div className="d-flex justify-content-between align-items-center">
          <h3 className="text-dark"><FaNotesMedical className="me-2" /> Health Information Reviews</h3>
          <div className="search-container">
            <div className="position-relative">
              <Form.Control
                type="text"
                placeholder="Search patients..."
                value={searchTerm}
                onChange={(e) => setSearchTerm(e.target.value)}
                className="search-input"
              />
              <FaSearch className="search-icon" />
            </div>
          </div>
        </div>
      </Card.Header>
      <Card.Body>
        {loading ? (
          <div className="text-center py-5">
            <Spinner animation="border" role="status" variant="primary">
              <span className="visually-hidden">Loading...</span>
            </Spinner>
            <p className="mt-2 text-dark">Loading patients...</p>
          </div>
        ) : error ? (
          <div className="alert alert-danger">{error}</div>
        ) : filteredPatients.length === 0 ? (
          <div className="no-data-message">
            <FaNotesMedical />
            <h4 className="text-dark">No patients waiting for health review</h4>
            <p className="text-muted">When users register and are verified by an admin, they will appear here for health assessment.</p>
          </div>
        ) : (

          <Row xs={1} md={1} className="g-4">
            {filteredPatients.map((patient) => (
              <Col key={patient.id}>
                <Card className={getCardClass(patient)}>
                  <Card.Body>
                    <div className="card-header-custom d-flex justify-content-between align-items-start">
                      <div>
                        <h4 className="patient-name">
                          <FaUserMd className="me-2" /> 
                          {patient.name} {patient.surname}
                        </h4>
                        <div className="d-flex align-items-center mb-2 status-section">
                          {getStatusBadge(patient)}
                          {getReportBadge(patient.reportCount)}
                              <i className="fas fa-user-check me-1"></i> Initial Review
                            </Badge>
                          )}
                          {patient.reportCount > 0 && (
                            <Badge bg="info" pill style={{ fontSize: '0.7rem', padding: '0.25em 0.6em' }}>
                              {patient.reportCount} {patient.reportCount === 1 ? 'Report' : 'Reports'}
                            </Badge>
                          )}
                        </Row>

                        <p><strong>Chronic Conditions:</strong> {patient.chronic_conditions || 'None'}</p>

                        <p>
                          <strong>Emergency Contact:</strong> {patient.emergency_contact_name} ({patient.emergency_contact_phone})
                        </p>
                      </div>

                      <div className="health-info-section assessment-section">
                        <h4 className="text-dark"><FaNotesMedical /> Health Assessment</h4>
                        <div className="health-questions">
                          <div className="health-question">
                            <span className="health-question-label">Heart problems/cardiovascular diseases:</span>
                            <div className={`health-answer ${patient.has_heart_problems === 'yes' || patient.has_heart_problems === 1 || patient.has_heart_problems === '1' || patient.has_heart_problems === true ? 'yes' : 'no'}`}>
                              {patient.has_heart_problems === 'yes' || patient.has_heart_problems === 1 || patient.has_heart_problems === '1' || patient.has_heart_problems === true ? 'Yes' : 'No'}
                            </div>
                          </div>
                          <div className="health-question">
                            <span className="health-question-label">Chest pain during physical activity:</span>
                            <div className={`health-answer ${patient.chest_pain_activity === 'yes' || patient.chest_pain_activity === 1 || patient.chest_pain_activity === '1' || patient.chest_pain_activity === true ? 'yes' : 'no'}`}>
                              {patient.chest_pain_activity === 'yes' || patient.chest_pain_activity === 1 || patient.chest_pain_activity === '1' || patient.chest_pain_activity === true ? 'Yes' : 'No'}
                            </div>
                          </div>
                          <div className="health-question">
                            <span className="health-question-label">Balance problems or dizziness:</span>
                            <div className={`health-answer ${patient.balance_dizziness === 'yes' || patient.balance_dizziness === 1 || patient.balance_dizziness === '1' || patient.balance_dizziness === true ? 'yes' : 'no'}`}>
                              {patient.balance_dizziness === 'yes' || patient.balance_dizziness === 1 || patient.balance_dizziness === '1' || patient.balance_dizziness === true ? 'Yes' : 'No'}
                            </div>
                          </div>
                          <div className="health-question">
                            <span className="health-question-label">Other chronic disease:</span>
                            <div className={`health-answer ${patient.other_chronic_disease === 'yes' || patient.other_chronic_disease === 1 || patient.other_chronic_disease === '1' || patient.other_chronic_disease === true ? 'yes' : 'no'}`}>
                              {patient.other_chronic_disease === 'yes' || patient.other_chronic_disease === 1 || patient.other_chronic_disease === '1' || patient.other_chronic_disease === true ? 'Yes' : 'No'}
                            </div>
                          </div>
                          <div className="health-question">
                            <span className="health-question-label">Prescribed medication:</span>
                            <div className={`health-answer ${patient.prescribed_medication === 'yes' || patient.prescribed_medication === 1 || patient.prescribed_medication === '1' || patient.prescribed_medication === true ? 'yes' : 'no'}`}>
                              {patient.prescribed_medication === 'yes' || patient.prescribed_medication === 1 || patient.prescribed_medication === '1' || patient.prescribed_medication === true ? 'Yes' : 'No'}
                            </div>
                          </div>
                          <div className="health-question">
                            <span className="health-question-label">Bone or joint issues:</span>
                            <div className={`health-answer ${patient.bone_joint_issues === 'yes' || patient.bone_joint_issues === 1 || patient.bone_joint_issues === '1' || patient.bone_joint_issues === true ? 'yes' : 'no'}`}>
                              {patient.bone_joint_issues === 'yes' || patient.bone_joint_issues === 1 || patient.bone_joint_issues === '1' || patient.bone_joint_issues === true ? 'Yes' : 'No'}
                            </div>
                          </div>
                          <div className="health-question">
                            <span className="health-question-label">Doctor supervised physical activity:</span>
                            <div className={`health-answer ${patient.doctor_supervised_activity === 'yes' || patient.doctor_supervised_activity === 1 || patient.doctor_supervised_activity === '1' || patient.doctor_supervised_activity === true ? 'yes' : 'no'}`}>
                              {patient.doctor_supervised_activity === 'yes' || patient.doctor_supervised_activity === 1 || patient.doctor_supervised_activity === '1' || patient.doctor_supervised_activity === true ? 'Yes' : 'No'}
                            </div>
                          </div>
                        </div>

                        {patient.health_additional_info && (
                          <div className="mt-2">
                            <strong>Additional Information:</strong>
                            <p className="ms-3">{patient.health_additional_info}</p>
                          </div>
                        )}
                      </div>

                      <div className="d-flex justify-content-center mb-3">
                        <Button 
                          variant="success" 
                          size="sm" 
                          className="action-button"
                          onClick={() => handleShowApprovalModal(patient)}
                        >
                          <i className="fas fa-check-circle me-1"></i>
                          Approve
                        </Button>
                        <Button 
                          variant="warning" 
                          size="sm"
                          onClick={() => handleShowReportModal(patient)}
                          className="action-button"
                        >
                          <i className="fas fa-file-medical me-1"></i>
                          Request Report
                        </Button>
                        <Button 
                          variant="danger" 
                          size="sm"
                          onClick={() => handleShowRejectModal(patient)}
                          className="action-button"
                        >
                          <i className="fas fa-times-circle me-1"></i>
                          Reject
                        </Button>
                        {(patient.health_status === 'pending' || patient.reportCount > 0) && (
                          <Button 
                            variant="info" 
                            size="sm"
                            onClick={() => handleViewHealthReports(patient)}
                            disabled={patient.reportCount === 0}
                            title={patient.reportCount === 0 ? "No reports available" : "View uploaded reports"}
                          >
                            <FaFileMedical className="me-1" />
                            View Reports
                          </Button>
                        )}
                      </div>
                    </Card.Body>
                  </Card>
                </Col>
              ))}
            </Row>
          )}
        </Card.Body>
      </Card>
        </Card.Body>
      </Card>

      {/* Approval Modal */}
      {showApprovalModal && (
        <div className="reason-modal">
          <div className="reason-modal-content">
            <div className="reason-header">
              <h3>Approve Health Status for {currentPatient?.name} {currentPatient?.surname}</h3>
              <button 
                className="close-modal" 
                onClick={() => setShowApprovalModal(false)}
                disabled={processing}
              >
                ×
              </button>
            </div>
            <div className="reason-container">
              <p>Approval notes (optional):</p>
              <textarea
                className="reason-textarea"
                value={approvalReason}
                onChange={(e) => setApprovalReason(e.target.value)}
                placeholder="Example: All health information verified successfully"
                disabled={processing}
              />
              <div className="reason-actions">
                <button
                  className="cancel-reason-btn"
                  onClick={() => setShowApprovalModal(false)}
                  disabled={processing}
                >
                  Cancel
                </button>
                <button
                  className="submit-reason-btn approve-btn"
                  onClick={handleApprove}
                  disabled={processing}
                >
                  {processing ? 'Processing...' : 'Confirm Approval'}
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* Request Additional Health Report Modal */}
      {showReportModal && (
        <div className="reason-modal">
          <div className="reason-modal-content">
            <div className="reason-header">
              <h3>Request Health Report from {currentPatient?.name} {currentPatient?.surname}</h3>
              <button 
                className="close-modal" 
                onClick={() => setShowReportModal(false)}
                disabled={processing}
              >
                ×
              </button>
            </div>
            <div className="reason-container">
              <p className="required-field">Reason for requesting health report:</p>
              <textarea
                className="reason-textarea"
                value={reportReason}
                onChange={(e) => setReportReason(e.target.value)}
                placeholder="Example: Need additional documentation about chronic conditions"
                required
                disabled={processing}
              />
              <p className="text-muted small mb-0">This will be sent to the user via email with upload instructions.</p>
              <div className="reason-actions">
                <button
                  className="cancel-reason-btn"
                  onClick={() => setShowReportModal(false)}
                  disabled={processing}
                >
                  Cancel
                </button>
                <button
                  className="submit-reason-btn report-btn"
                  onClick={handleRequestReport}
                  disabled={!reportReason.trim() || processing}
                >
                  {processing ? 'Processing...' : 'Request Report'}
                </button>
              </div>
            </div>
          </div>
        </div>
      )}
      
      {/* Reject Health Status Modal */}
      {showRejectModal && (
        <div className="reason-modal">
          <div className="reason-modal-content">
            <div className="reason-header">
              <h3>Reject Health Status for {currentPatient?.name} {currentPatient?.surname}</h3>
              <button 
                className="close-modal" 
                onClick={() => setShowRejectModal(false)}
                disabled={processing}
              >
                ×
              </button>
            </div>
            <div className="reason-container">
              <p className="required-field">Reason for rejection (required):</p>
              <textarea
                className="reason-textarea"
                value={rejectReason}
                onChange={(e) => setRejectReason(e.target.value)}
                placeholder="Example: Medical condition incompatible with swimming activities"
                required
                disabled={processing}
              />
              <p className="text-muted small mb-0">The user will be notified via email with this reason. They will be able to reapply after 30 days.</p>
              <div className="reason-actions">
                <button
                  className="cancel-reason-btn"
                  onClick={() => setShowRejectModal(false)}
                  disabled={processing}
                >
                  Cancel
                </button>
                <button
                  className="submit-reason-btn reject-btn"
                  onClick={handleReject}
                  disabled={!rejectReason.trim() || processing}
                  style={{ backgroundColor: '#dc3545', borderColor: '#dc3545' }}
                >
                  {processing ? 'Processing...' : 'Reject Health Status'}
                </button>
              </div>
            </div>
          </div>
        </div>
      )}
      
      {/* View Health Reports Modal */}
      {showHealthReportsModal && currentPatient && (
        <div className="reason-modal">
          <div className="reason-modal-content">
            <div className="reason-header">
              <h3>Health Reports - {currentPatient?.name} {currentPatient?.surname}</h3>
              <button 
                className="close-modal" 
                onClick={() => setShowHealthReportsModal(false)}
              >
                ×
              </button>
            </div>
            <div className="reason-container">
              {loadingReports ? (
                <div className="text-center p-4">
                  <Spinner animation="border" role="status" variant="primary">
                    <span className="visually-hidden">Loading...</span>
                  </Spinner>
                </div>
              ) : healthReports.length > 0 ? (
                <>
                  <p>The patient has submitted the following health reports:</p>
                  <ListGroup className="mb-3">
                    {healthReports.map((report, index) => (
                      <ListGroup.Item key={report.id} className="d-flex justify-content-between align-items-center">
                        <div>
                          <strong>Report #{index + 1}</strong>
                          <div className="text-muted small">Submitted: {formatDate(report.created_at)}</div>
                        </div>
                        <div>
                          <Button
                            variant="outline-primary"
                            size="sm"
                            className="me-2"
                            href={`http://localhost:3001/uploads/health_reports/${report.report_path.split('/').pop()}`}
                            target="_blank"
                          >
                            <FaEye className="me-1" /> View
                          </Button>
                          <Button
                            variant="outline-success"
                            size="sm"
                            href={`http://localhost:3001/uploads/health_reports/${report.report_path.split('/').pop()}?download=true`}
                          >
                            <FaFileDownload className="me-1" /> Download
                          </Button>
                        </div>
                      </ListGroup.Item>
                    ))}
                  </ListGroup>
                </>
              ) : (

                <Alert variant="info">
                  No health reports found for this patient. If they were recently requested, the patient may not have uploaded them yet.
                </Alert>
              )}
              <div className="reason-actions">
                <button
                  className="cancel-reason-btn"
                  onClick={() => setShowHealthReportsModal(false)}
                >
                  Close
                </button>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
};

export default HealthReviewQueue;
